# OBS Events — client build-time env template (§4.5).
# Copy to client/.env.production before `npm run build --workspace client`.
# Vite inlines these at build time, so they are PUBLIC — never put secrets here.

# API base (same-origin behind nginx/CloudFront, so the /api/v1 path is enough).
VITE_API_URL=https://obsevents.com/api/v1

# Google Sign-In client id (public) — enables the "Continue with Google" button.
VITE_GOOGLE_CLIENT_ID=

# Google Maps browser key — HTTP-referrer restricted, Maps JS + Places only.
VITE_GOOGLE_MAPS_API_KEY=
