# OBS Events — server production env template (§4.5).
# Copy to server/.env on the EC2 host and fill in real values. NEVER commit .env.
# Every key below is read in server/src/config/env.js.

NODE_ENV=production
PORT=4000

# Public URLs (used for links, CORS, sitemap/robots, OG, webhook return links).
APP_URL=https://obsevents.com
API_URL=https://obsevents.com
# CORS allowlist — every browser origin that calls the API (comma-separated).
CORS_ORIGINS=https://obsevents.com,https://www.obsevents.com

# --- MongoDB Atlas (M10 prod). Create a DB user + allowlist the EC2 IP/VPC. ---
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/obs?retryWrites=true&w=majority
# Leave DNS_SERVERS empty in prod (only a dev workaround for routers blocking TCP DNS).
DNS_SERVERS=

# --- Auth secrets (generate strong random values, e.g. `openssl rand -hex 48`) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
RESET_TOKEN_TTL=30m

# --- Seed admin (run `npm run seed --workspace server` once) ---
SEED_ADMIN_EMAIL=admin@obsevents.com
SEED_ADMIN_PASSWORD=

# --- Google (Sign-In + Maps). Server Maps key = Geocoding API only. ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_MAPS_API_KEY=

# --- AWS S3 (private bucket; ticket/invoice PDFs are read via signed URLs). ---
# On EC2 prefer an IAM instance role over static keys (then leave these empty).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=obs-events-prod

# --- Payments (Stripe only, all currencies incl. INR): switch to LIVE keys at launch. ---
SERVICE_FEE_PERCENT=5
ORDER_HOLD_MINUTES=15
REFUND_CUTOFF_HOURS=24
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=OBS Events <tickets@obsevents.com>
