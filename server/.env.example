# OBS Events — server environment (copy to .env and fill in).
# See obs-events-build-plan.md §12. Never commit the real .env.

# --- Core ---
MONGODB_URI=mongodb://127.0.0.1:27017/obs-events?replicaSet=rs0   # Atlas SRV in prod; local single-node RS in dev (transactions need a replica set)
PORT=4000
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
# CORS allowlist (comma-separated). Defaults to APP_URL. In prod list every
# browser origin that calls the API, e.g. https://obsevents.com,https://admin.obsevents.com
CORS_ORIGINS=http://localhost:5173
# Optional dev-only: if mongodb+srv:// SRV lookups fail (ECONNREFUSED) behind a
# router that blocks TCP DNS, point Node's resolver at a public DNS. Empty in prod.
DNS_SERVERS=

# --- Auth (Phase 0.3) ---
JWT_ACCESS_SECRET=            # generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_REFRESH_SECRET=
GOOGLE_CLIENT_ID=             # required to verify Google id_token sign-in (must match the client VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_SECRET=
# Optional overrides (defaults shown): token TTLs + rate-limit maxes.
# ACCESS_TOKEN_TTL=15m
# REFRESH_TOKEN_TTL=30d
# RESET_TOKEN_TTL=30m
# RATE_LIMIT_MAX=100           # global, per 15 min
# AUTH_RATE_LIMIT_MAX=10       # auth credential routes, per 15 min

# --- Storage: AWS S3 (Phase 0.4) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=obs-events

# --- Email: Nodemailer SMTP (Phase 0.4) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="OBS Events <tickets@obs.business>"

# --- Payments (Stripe only — all currencies incl. INR) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Google Maps (server key — Geocoding fallback, §8.7) ---
GOOGLE_MAPS_API_KEY=

# --- Business rules ---
SERVICE_FEE_PERCENT=5
ORDER_HOLD_MINUTES=15
REFUND_CUTOFF_HOURS=24

# --- Seed (Phase 0.2) ---
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
